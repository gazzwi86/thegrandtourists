{
  "name": "thegrandtourists",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "scrape": "npx tsx scripts/scrape.ts",
    "optimize-images": "npx tsx scripts/optimize-images.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:compare": "npx tsx tests/compare.ts",
    "lint": "eslint src --ext .ts,.astro && astro check",
    "typecheck": "tsc --noEmit",
    "lighthouse": "lhci autorun",
    "deploy:s3:assets": "aws s3 sync dist/ s3://$S3_BUCKET --delete --exclude '*.html' --cache-control 'public, max-age=31536000, immutable' --profile gazzwi86",
    "deploy:s3:html": "aws s3 sync dist/ s3://$S3_BUCKET --exclude '*' --include '*.html' --cache-control 'public, max-age=0, must-revalidate' --profile gazzwi86",
    "deploy:invalidate": "aws cloudfront create-invalidation --distribution-id $CLOUDFRONT_DISTRIBUTION_ID --paths '/*' --profile gazzwi86",
    "deploy": "npm run build && npm run deploy:s3:assets && npm run deploy:s3:html && npm run deploy:invalidate",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/abril-fatface": "^5.2.5",
    "@fontsource/lato": "^5.2.5",
    "@fontsource/neuton": "^5.2.5",
    "@fontsource/oswald": "^5.2.8",
    "astro": "^6.4.4",
    "astro-pagefind": "^1.7.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.49.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "cheerio": "^1.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-astro": "^1.3.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "he": "^1.2.0",
    "husky": "^9.0.0",
    "js-yaml": "^4.1.0",
    "lint-staged": "^15.0.0",
    "node-fetch": "^3.3.2",
    "p-limit": "^6.1.0",
    "prettier": "^3.0.0",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.33.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,astro}": [
      "eslint --fix"
    ],
    "*.{ts,astro,css,md}": "prettier --write"
  }
}
