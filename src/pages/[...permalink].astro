---
import Base from '../layouts/Base.astro'
import Sidebar from '../components/Sidebar.astro'
import Lightbox from '../components/Lightbox.astro'
import { getSortedPosts, formatDate, tagSlug } from '../lib/posts'
import { SITE_URL, CATEGORIES } from '../config/site'

export async function getStaticPaths() {
  const allPosts = await getSortedPosts()
  const filteredPosts = allPosts.filter((post) => {
    const p = post.data.permalink
    return !p.startsWith('page/') && !p.startsWith('category/')
  })
  return filteredPosts.map((post, index) => ({
    params: { permalink: post.data.permalink },
    props: { post, allPosts: filteredPosts, currentIndex: index }
  }))
}

const { post, allPosts, currentIndex } = Astro.props
const {
  title,
  date,
  excerpt,
  body,
  featuredImage,
  featuredImageWidth,
  featuredImageHeight,
  categories,
  tags,
  permalink
} = post.data

const MAX_OG_DIM = 1440
const ogWidth = featuredImageWidth ? Math.min(featuredImageWidth, MAX_OG_DIM) : undefined
const ogHeight =
  featuredImageHeight && featuredImageWidth && featuredImageWidth > MAX_OG_DIM
    ? Math.round((featuredImageHeight * MAX_OG_DIM) / featuredImageWidth)
    : featuredImageHeight

const postUrl = `${SITE_URL}/${permalink}/`

const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null
---

<Base
  title={title}
  description={excerpt}
  canonicalUrl={postUrl}
  ogImage={featuredImage}
  ogImageWidth={ogWidth}
  ogImageHeight={ogHeight}
  type="article"
  showHero={!!featuredImage}
  article={{
    publishedTime: date.toISOString(),
    tags: tags ?? []
  }}
>
  {
    featuredImage && (
      <link slot="head" rel="preload" as="image" href={featuredImage} fetchpriority="high" />
    )
  }
  {
    featuredImage && (
      <section
        class="post-hero"
        style={`background-image: url('${featuredImage}')`}
        aria-label="Post header"
      >
        <div class="container">
          <div class="post-hero__inner">
            <div class="post-meta">
              <time datetime={date.toISOString()}>{formatDate(date)}</time>
              {categories.map((cat: string) => (
                <>
                  <span aria-hidden="true">&middot;</span>
                  <a
                    href={`/category/${cat}/`}
                    class="category-pill hero-pill"
                    aria-label={`Category: ${CATEGORIES[cat] ?? cat}`}
                  >
                    {CATEGORIES[cat] ?? cat}
                  </a>
                </>
              ))}
            </div>
            <h1 class="post-title">{title}</h1>
          </div>
        </div>
      </section>
    )
  }

  <div class="container site-body">
    <div class="two-col">
      <article class="main-content">
        {
          !featuredImage && (
            <header class="post-header">
              <div class="post-meta">
                <time datetime={date.toISOString()}>{formatDate(date)}</time>
                {categories.map((cat: string) => (
                  <>
                    <span aria-hidden="true">&middot;</span>
                    <a
                      href={`/category/${cat}/`}
                      class="category-pill"
                      aria-label={`Category: ${CATEGORIES[cat] ?? cat}`}
                    >
                      {CATEGORIES[cat] ?? cat}
                    </a>
                  </>
                ))}
              </div>
              <h1 class="post-title">{title}</h1>
            </header>
          )
        }

        <div class="entry-content">
          <Fragment set:html={body} />
        </div>

        {
          tags && tags.length > 0 && (
            <footer class="post-tags" aria-label="Post tags">
              {tags.map((tag: string) => (
                <a href={`/tag/${tagSlug(tag)}/`} class="tag">
                  {tag}
                </a>
              ))}
            </footer>
          )
        }

        <nav class="post-nav" aria-label="Post navigation">
          {
            prevPost ? (
              <a href={`/${prevPost.data.permalink}/`} rel="prev">
                &larr; {prevPost.data.title}
              </a>
            ) : (
              <span />
            )
          }
          {
            nextPost && (
              <a href={`/${nextPost.data.permalink}/`} rel="next">
                {nextPost.data.title} &rarr;
              </a>
            )
          }
        </nav>
      </article>

      <Sidebar />
    </div>
  </div>
  <Lightbox />
</Base>
