---
import Base from '../../../../layouts/Base.astro'
import PostCard from '../../../../components/PostCard.astro'
import Sidebar from '../../../../components/Sidebar.astro'
import { getPostsByCategory, paginatePosts } from '../../../../lib/posts'
import { SITE_TITLE, CATEGORIES } from '../../../../config/site'

export async function getStaticPaths() {
  const paths = []
  for (const [slug] of Object.entries(CATEGORIES)) {
    const catPosts = await getPostsByCategory(slug)
    if (catPosts.length <= 10) continue // no pagination needed
    const totalPages = Math.ceil(catPosts.length / 10)
    for (let page = 2; page <= totalPages; page++) {
      paths.push({
        params: { category: slug, page: String(page) },
        props: { page },
      })
    }
  }
  return paths
}

const { category } = Astro.params
const { page } = Astro.props
const categoryLabel = CATEGORIES[category as string] ?? category
const allCatPosts = await getPostsByCategory(category as string)
const { posts, totalPages, hasPrev, hasNext } = paginatePosts(allCatPosts, page)
---

<Base
  title={`${categoryLabel} — Page ${page} | ${SITE_TITLE}`}
  description={`Travel posts about ${categoryLabel}, page ${page}`}
>
  <!-- rel=prev/next for SEO -->
  {hasPrev && (
    <link slot="head" rel="prev" href={page === 2 ? `/category/${category}/` : `/category/${category}/page/${page - 1}/`} />
  )}
  {hasNext && (
    <link slot="head" rel="next" href={`/category/${category}/page/${page + 1}/`} />
  )}

  <div class="container site-body">
    <div class="two-col">
      <div class="main-content">
        <h1 class="archive-title">{categoryLabel}</h1>
        <div class="post-grid">
          {posts.map((post) => (
            <PostCard
              title={post.data.title}
              permalink={post.data.permalink}
              date={post.data.date}
              excerpt={post.data.excerpt}
              featuredImage={post.data.featuredImage}
              featuredImageAlt={post.data.featuredImageAlt}
              categories={post.data.categories}
            />
          ))}
        </div>
        <nav class="pagination" aria-label="Page navigation">
          {hasPrev && (
            <a href={page === 2 ? `/category/${category}/` : `/category/${category}/page/${page - 1}/`} aria-label="Previous page">
              &larr; Newer
            </a>
          )}
          <span class="current">{page} / {totalPages}</span>
          {hasNext && (
            <a href={`/category/${category}/page/${page + 1}/`} aria-label="Next page">Older &rarr;</a>
          )}
        </nav>
      </div>
      <Sidebar />
    </div>
  </div>
</Base>
