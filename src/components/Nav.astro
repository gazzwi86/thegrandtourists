---
import { SITE_TITLE, SITE_TAGLINE } from '../config/site'

interface Props {
  showHero?: boolean
}

const { showHero = false } = Astro.props
const currentPath = Astro.url.pathname
const isHomepage = currentPath === '/'

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/'
  return currentPath.startsWith(href)
}

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/category/australia/', label: 'Australia' },
  { href: '/category/new-zealand/', label: 'New Zealand' },
  { href: '/category/south-america/', label: 'South America' }
]
---

<header class={`site-header${showHero ? ' has-hero' : ''}`} role="banner">
  <div class="container">
    <div class="site-branding">
      {
        isHomepage ? (
          <h1 class="site-title">
            <a href="/">{SITE_TITLE}</a>
          </h1>
        ) : (
          <a href="/" class="site-title">
            {SITE_TITLE}
          </a>
        )
      }
      <p class="site-tagline">{SITE_TAGLINE}</p>
    </div>
    <nav class="site-nav" aria-label="Main navigation">
      <ul class="nav-list">
        {
          navLinks.map(({ href, label }) => {
            const active = isActive(href)
            return (
              <li>
                <a
                  href={href}
                  aria-current={active ? 'page' : undefined}
                  class={active ? 'active' : undefined}
                >
                  {label}
                </a>
              </li>
            )
          })
        }
      </ul>
    </nav>
  </div>
</header>
