---
import { formatDate } from '../lib/posts'
import { CATEGORIES } from '../config/site'

interface Props {
  title: string
  permalink: string
  date: Date
  excerptHtml: string
  featuredImage?: string
  featuredImageAlt?: string
  categories?: string[]
}

const {
  title,
  permalink,
  date,
  excerptHtml,
  featuredImage,
  featuredImageAlt = '',
  categories = []
} = Astro.props

const postUrl = `/${permalink}/`
---

<article class="post-card">
  <div class="post-card__body">
    <div class="post-card__meta">
      <time datetime={date.toISOString()}>{formatDate(date)}</time>
      {
        categories.map((cat) => (
          <>
            <span aria-hidden="true">&middot;</span>
            <a
              href={`/category/${cat}/`}
              class="category-pill"
              aria-label={`Category: ${CATEGORIES[cat] ?? cat}`}
            >
              {CATEGORIES[cat] ?? cat}
            </a>
          </>
        ))
      }
    </div>

    <h2 class="post-card__title">
      <a href={postUrl}>{title}</a>
    </h2>

    <div class="post-card__excerpt">
      <Fragment set:html={excerptHtml} />
    </div>

    <a href={postUrl} class="read-more" aria-label={`Continue reading about ${title}`}>
      Continue reading &rarr;
    </a>
  </div>

  {
    featuredImage && (
      <a href={postUrl} tabindex="-1" aria-hidden="true" class="post-card__thumb">
        <img
          src={featuredImage.replace(/\.webp$/, '-600.webp')}
          alt={featuredImageAlt || ''}
          loading="lazy"
          width="144"
          height="144"
        />
      </a>
    )
  }
</article>
