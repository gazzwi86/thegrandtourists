---
// Lightbox — attaches to .entry-content img elements on post pages
---

<dialog id="lightbox" class="lightbox" aria-label="Image viewer">
  <button class="lightbox__close" type="button" aria-label="Close image viewer">
    <svg
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      aria-hidden="true"
      focusable="false"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
  <button class="lightbox__prev" type="button" aria-label="Previous image">
    <svg
      width="28"
      height="28"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      aria-hidden="true"
      focusable="false"
    >
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>
  <button class="lightbox__next" type="button" aria-label="Next image">
    <svg
      width="28"
      height="28"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      aria-hidden="true"
      focusable="false"
    >
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </button>
  <figure class="lightbox__figure">
    <img class="lightbox__img" src="" alt="" />
    <figcaption class="lightbox__caption"></figcaption>
  </figure>
</dialog>

<style>
  .lightbox {
    border: none;
    padding: 0;
    background: rgba(0, 0, 0, 0.93);
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .lightbox:not([open]) {
    display: none;
  }

  .lightbox__figure {
    max-width: min(90vw, 1200px);
    max-height: 90vh;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .lightbox__img {
    max-width: min(90vw, 1200px);
    max-height: 80vh;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    cursor: default;
  }

  .lightbox__caption {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
    font-style: italic;
    text-align: center;
    margin-top: 0.75rem;
    max-width: 60ch;
    padding: 0 1rem;
  }

  .lightbox__close,
  .lightbox__prev,
  .lightbox__next {
    position: absolute;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border-radius: 2px;
    transition: background 0.15s;
  }

  .lightbox__close:hover,
  .lightbox__prev:hover,
  .lightbox__next:hover {
    background: rgba(255, 255, 255, 0.22);
  }

  .lightbox__close {
    top: 1rem;
    right: 1rem;
    width: 2.5rem;
    height: 2.5rem;
  }

  .lightbox__prev {
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 3rem;
    height: 3rem;
  }

  .lightbox__next {
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 3rem;
    height: 3rem;
  }

  .lightbox__prev:disabled,
  .lightbox__next:disabled {
    opacity: 0.25;
    cursor: default;
    pointer-events: none;
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox') as HTMLDialogElement | null
  if (lightbox) {
    const imgEl = lightbox.querySelector('.lightbox__img') as HTMLImageElement | null
    const captionEl = lightbox.querySelector('.lightbox__caption') as HTMLElement | null
    const closeBtn = lightbox.querySelector('.lightbox__close') as HTMLButtonElement | null
    const prevBtn = lightbox.querySelector('.lightbox__prev') as HTMLButtonElement | null
    const nextBtn = lightbox.querySelector('.lightbox__next') as HTMLButtonElement | null

    let images: HTMLImageElement[] = []
    let currentIndex = 0

    function getLargestSrc(img: HTMLImageElement): string {
      const srcset = img.getAttribute('srcset')
      if (!srcset) return img.src
      const sources = srcset.split(',').map((s) => {
        const parts = s.trim().split(/\s+/)
        return { url: parts[0] ?? '', width: parseInt(parts[1] ?? '0') || 0 }
      })
      sources.sort((a, b) => b.width - a.width)
      return sources[0]?.url ?? img.src
    }

    function updateNav() {
      if (prevBtn) prevBtn.disabled = currentIndex === 0
      if (nextBtn) nextBtn.disabled = currentIndex === images.length - 1
    }

    function showImage(index: number) {
      const img = images[index]
      if (!img) return
      currentIndex = index
      if (imgEl) {
        imgEl.src = getLargestSrc(img)
        imgEl.alt = img.alt || ''
      }
      if (captionEl) {
        const caption = img.getAttribute('data-caption') || img.alt || ''
        captionEl.textContent = caption
        captionEl.hidden = !caption
      }
      updateNav()
    }

    const openLightbox = (index: number) => {
      showImage(index)
      lightbox.showModal()
    }

    const content = document.querySelector('.entry-content')
    if (content) {
      images = (Array.from(content.querySelectorAll('img')) as HTMLImageElement[]).filter(
        (img) => !img.closest('a')
      )
      images.forEach((img, i) => {
        img.addEventListener('click', () => openLightbox(i))
      })
    }

    closeBtn?.addEventListener('click', () => lightbox.close())
    prevBtn?.addEventListener('click', () => {
      if (currentIndex > 0) showImage(currentIndex - 1)
    })
    nextBtn?.addEventListener('click', () => {
      if (currentIndex < images.length - 1) showImage(currentIndex + 1)
    })

    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) lightbox.close()
    })

    document.addEventListener('keydown', (e) => {
      if (!lightbox.open) return
      if (e.key === 'ArrowLeft' && currentIndex > 0) showImage(currentIndex - 1)
      else if (e.key === 'ArrowRight' && currentIndex < images.length - 1)
        showImage(currentIndex + 1)
    })
  }
</script>
